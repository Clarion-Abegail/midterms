<Window x:Class="Asynchronous_Activity.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Asynchronous_Activity"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <StackPanel Orientation="Vertical">          
    <Grid Background="#FFA4DCA4">
        <TextBlock Text="Shopping Cart System" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="25" FontWeight="Bold"/>
        <TextBlock Text="Available Items" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="15" Margin="45"/>
        <TextBlock Text="Shopping Cart" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="15" Margin="205"/>
        <DataGrid x:Name="myGridData" ItemsSource="{Binding Items}" AutoGenerateColumns = "False" Margin="10,70,10,234">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="*"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="3*"/>
                <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <DataGrid x:Name="myGridData2" ItemsSource="{Binding Itemss}" AutoGenerateColumns = "False" Height="100" Margin="10,230,10,104">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="*"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="3*"/>
                <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="*"/>
                </DataGrid.Columns>
        </DataGrid>

            <StackPanel  Orientation="Horizontal" HorizontalAlignment="Center" Margin="10,330,10,0">
                <!--Id-->
                <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="5">
                    <Label Content="Id"/>
                    <TextBox x:Name="txtId" Width="40"/>
                </StackPanel>
               
                <!--Name-->
                <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="5">
                    <Label Content="Name"/>
                    <TextBox x:Name="txtName" Width="80"/>
                </StackPanel>
 
                <!--Description-->
                <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="5">
                    <Label Content="Description"/>
                    <TextBox x:Name="txtDescription" Width="200"/>
                </StackPanel>
                
                <!--Price-->
                <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="5">
                    <Label Content="Price"/>
                    <TextBox x:Name="txtPrice" Width="80"/>
                </StackPanel>
            </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Height="30" Margin="20" VerticalAlignment="Bottom">
            <Button x:Name="btnAdd" Content="Add" Margin="5" Width="100" Click="btnAdd_Click"/>
            <Button x:Name="btnRemove" Content="Remove" Margin="5" Width="100"  Click="btnRemove_Click"/>
            <Button x:Name="btnClear" Content="Clear" Margin="5" Width="100" Click="btnClear_Click"/>
            <Button x:Name="btnAddtoCart" Content="Add to Cart" Margin="5" Width="100" Click="btnAddtoCart_Click"/>
            <Button x:Name="btnRemovefromCart" Content="Remove from Cart" Margin="5" Width="100" Click="btnRemovefromCart_Click"/>
        </StackPanel>
    </Grid>
    </StackPanel>
</Window>
